{
  "workbench.colorTheme": "Visual Studio Dark",
  "workbench.colorCustomizations": {
    "editor.foreground": "#cdd6f4",
    "editorLineNumber.foreground": "#585b70",
    "editorLineNumber.activeForeground": "#cba6f7",
    "editor.selectionBackground": "#585b7066",
    "editor.wordHighlightBackground": "#31324488",
    "editor.findMatchBackground": "#f9e2af44",
    "editor.findMatchHighlightBackground": "#f9e2af22",
    "editor.lineHighlightBackground": "#31324466",
    "editorCursor.foreground": "#f5c2e7",
    "sideBar.background": "#181825",
    "sideBar.foreground": "#cdd6f4",
    "sideBarTitle.foreground": "#cba6f7",
    "sideBarSectionHeader.background": "#1e1e2e",
    "sideBarSectionHeader.foreground": "#cba6f7",
    "sideBarSectionHeader.border": "#313244",
    "activityBar.background": "#181825",
    "activityBar.foreground": "#cdd6f4",
    "activityBar.inactiveForeground": "#585b70",
    "activityBar.activeBorder": "#cba6f7",
    "activityBar.activeBackground": "#313244",
    "activityBarBadge.background": "#cba6f7",
    "activityBarBadge.foreground": "#1e1e2e",
    "titleBar.activeBackground": "#181825",
    "titleBar.activeForeground": "#cdd6f4",
    "titleBar.inactiveBackground": "#181825",
    "titleBar.inactiveForeground": "#585b70",
    "titleBar.border": "#313244",
    "tab.activeBackground": "#1e1e2e",
    "tab.activeForeground": "#cdd6f4",
    "tab.inactiveBackground": "#181825",
    "tab.inactiveForeground": "#585b70",
    "tab.activeBorderTop": "#cba6f7",
    "tab.border": "#313244",
    "tab.unfocusedActiveBorderTop": "#585b70",
    "statusBar.background": "#181825",
    "statusBar.foreground": "#cdd6f4",
    "statusBar.noFolderBackground": "#181825",
    "statusBar.debuggingBackground": "#181825",
    "statusBar.border": "#313244",
    "statusBarItem.hoverBackground": "#313244",
    "statusBarItem.remoteBackground": "#45475a",
    "statusBarItem.remoteForeground": "#cdd6f4",
    "panel.background": "#181825",
    "panel.border": "#313244",
    "panelTitle.activeForeground": "#cba6f7",
    "panelTitle.activeBorder": "#cba6f7",
    "panelTitle.inactiveForeground": "#585b70",
    "input.background": "#313244",
    "input.foreground": "#cdd6f4",
    "input.border": "#585b70",
    "input.placeholderForeground": "#6c7086",
    "inputOption.activeBorder": "#cba6f7",
    "inputOption.activeBackground": "#45475a",
    "dropdown.background": "#313244",
    "dropdown.foreground": "#cdd6f4",
    "dropdown.border": "#585b70",
    "button.background": "#cba6f7",
    "button.foreground": "#1e1e2e",
    "button.hoverBackground": "#b4befe",
    "button.secondaryBackground": "#45475a",
    "button.secondaryForeground": "#cdd6f4",
    "list.activeSelectionBackground": "#313244",
    "list.activeSelectionForeground": "#cdd6f4",
    "list.hoverBackground": "#2a2a3d",
    "list.inactiveSelectionBackground": "#2a2a3d",
    "list.focusBackground": "#313244",
    "list.highlightForeground": "#cba6f7",
    "scrollbarSlider.background": "#45475a",
    "scrollbarSlider.hoverBackground": "#585b70",
    "scrollbarSlider.activeBackground": "#6c7086",
    "breadcrumb.background": "#1e1e2e",
    "breadcrumb.foreground": "#585b70",
    "breadcrumb.activeSelectionForeground": "#cdd6f4",
    "notifications.background": "#313244",
    "notifications.foreground": "#cdd6f4",
    "notificationCenterHeader.background": "#181825",
    "notificationCenterHeader.foreground": "#cba6f7",
    "quickInput.background": "#313244",
    "quickInput.foreground": "#cdd6f4",
    "quickInputTitle.background": "#45475a",
    "pickerGroup.border": "#cba6f7",
    "pickerGroup.foreground": "#cba6f7",
    "focusBorder": "#cba6f7",
    "widget.border": "#313244",
    "widget.shadow": "#11111b",
    "selection.background": "#cba6f7",
    "terminal.background": "#181825",
    "terminal.foreground": "#cdd6f4"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      { "scope": "keyword", "settings": { "foreground": "#cba6f7" } },
      { "scope": "keyword.operator", "settings": { "foreground": "#89dceb" } },
      { "scope": "keyword.control", "settings": { "foreground": "#cba6f7" } },
      { "scope": "storage.type", "settings": { "foreground": "#cba6f7" } },
      { "scope": "storage.modifier", "settings": { "foreground": "#cba6f7" } },
      { "scope": "entity.name.function", "settings": { "foreground": "#89b4fa" } },
      { "scope": "entity.name.class", "settings": { "foreground": "#f9e2af" } },
      { "scope": "entity.name.type", "settings": { "foreground": "#f9e2af" } },
      { "scope": "entity.name.tag", "settings": { "foreground": "#f38ba8" } },
      { "scope": "entity.other.attribute-name", "settings": { "foreground": "#f9e2af" } },
      { "scope": "variable", "settings": { "foreground": "#cdd6f4" } },
      { "scope": "variable.parameter", "settings": { "foreground": "#fab387" } },
      { "scope": "variable.other.constant", "settings": { "foreground": "#fab387" } },
      { "scope": "string", "settings": { "foreground": "#a6e3a1" } },
      { "scope": "string.regexp", "settings": { "foreground": "#89dceb" } },
      { "scope": "constant.numeric", "settings": { "foreground": "#fab387" } },
      { "scope": "constant.language", "settings": { "foreground": "#cba6f7" } },
      { "scope": "constant.character.escape", "settings": { "foreground": "#89dceb" } },
      { "scope": "comment", "settings": { "foreground": "#6c7086", "fontStyle": "italic" } },
      { "scope": "punctuation", "settings": { "foreground": "#cdd6f4" } },
      { "scope": "support.function", "settings": { "foreground": "#89dceb" } },
      { "scope": "support.class", "settings": { "foreground": "#f9e2af" } },
      { "scope": "support.type", "settings": { "foreground": "#89dceb" } },
      { "scope": "support.constant", "settings": { "foreground": "#fab387" } }
    ]
  },
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Menlo, monospace",
  "editor.fontSize": 13,
  "editor.lineHeight": 1.6,
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.wordWrap": "off",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "workbench.activityBar.location": "default",
  "workbench.sideBar.location": "left",
  "workbench.panel.defaultLocation": "bottom",
  "workbench.startupEditor": "welcomePage",
  "workbench.iconTheme": "vs-seti",
  "workbench.tree.indent": 16,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.secondarySideBar.location": "right",
  "kilocode.showWelcomeView": true,
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', Menlo, monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true
  },
  "extensions.autoUpdate": false,
  "telemetry.telemetryLevel": "off",
  "window.titleBarStyle": "custom",
  "window.title": "${rootName} — RECODE IDE",
  "window.newWindowDimensions": "maximized",
  "window.zoomLevel": 0,
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
    "kilo-code.new.agentManager.runScript"
  ],
  "terminal.integrated.gpuAcceleration": "off",
  "window.systemColorTheme": "dark",
  "window.autoDetectColorScheme": false
}
